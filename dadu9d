<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dadu 9D Simulator</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial,sans-serif;
}

body{
    background:#232733;
    color:white;
    text-align:center;
    padding:20px;
}

h1{
    margin-bottom:20px;
}

.board{
    background:#2c3140;
    border-radius:15px;
    padding:25px;
    max-width:500px;
    margin:auto;
}

.grid{
    display:grid;
    grid-template-columns:repeat(3,90px);
    gap:20px;
    justify-content:center;
}

.dice{
    width:90px;
    height:90px;
    background:#26c6da;
    color:white;
    font-size:40px;
    font-weight:bold;
    display:flex;
    justify-content:center;
    align-items:center;
    border-radius:6px;
}

.total{
    margin-top:20px;
    font-size:40px;
    font-weight:bold;
}

.buttons{
    margin-top:20px;
}

button{
    padding:12px 18px;
    margin:5px;
    border:none;
    border-radius:10px;
    cursor:pointer;
    font-size:16px;
}

.roll{
    background:#8fb6ff;
}

.clear{
    background:#444;
    color:white;
}

.manual{
    background:#00c853;
    color:white;
}

.target{
    background:#ff9800;
    color:white;
}

input{
    width:200px;
    padding:10px;
    border:none;
    border-radius:8px;
    margin-top:15px;
    text-align:center;
    font-size:18px;
}
</style>
</head>
<body>

<h1>Dadu 9D Online</h1>

<div class="board">

<div class="grid" id="grid">

<div class="dice">1</div>
<div class="dice">1</div>
<div class="dice">1</div>

<div class="dice">1</div>
<div class="dice">1</div>
<div class="dice">1</div>

<div class="dice">1</div>
<div class="dice">1</div>
<div class="dice">1</div>

</div>

<div class="total" id="total">
Total 9
</div>

<input
type="number"
id="targetTotal"
placeholder="Masukkan Total"
/>

<div class="buttons">

<button class="roll" onclick="rollRandom()">
Lempar
</button>

<button class="clear" onclick="clearDice()">
Hapus
</button>

<button class="manual" onclick="setManual()">
Set Manual
</button>

<button class="target" onclick="setTotal()">
Set Total
</button>

</div>

</div>

<script>

const dices =
document.querySelectorAll(".dice");

function updateTotal(){

let total = 0;

dices.forEach(d=>{

total += parseInt(d.innerText);

});

document.getElementById("total").innerText =
"Total " + total;
}

function rollRandom(){

dices.forEach(d=>{

d.innerText =
Math.floor(Math.random()*6)+1;

});

updateTotal();
}

function clearDice(){

dices.forEach(d=>{

d.innerText = 1;

});

updateTotal();
}

function setManual(){

let data = prompt(
"Masukkan 9 angka (1-6)\nContoh:\n6,6,6,6,6,6,6,6,6"
);

if(!data) return;

let arr = data.split(",");

if(arr.length != 9){

alert("Harus 9 angka");
return;

}

for(let i=0;i<9;i++){

let n = parseInt(arr[i]);

if(n<1 || n>6){

alert("Angka hanya 1-6");
return;

}

dices[i].innerText = n;

}

updateTotal();
}

function generateTotal(target){

if(target < 9 || target > 54){

alert("Total harus 9 - 54");
return null;

}

let arr = [1,1,1,1,1,1,1,1,1];

let sisa = target - 9;

for(let i=0;i<9;i++){

let tambah = Math.min(5,sisa);

arr[i]+=tambah;

sisa-=tambah;

}

return arr;
}

function setTotal(){

let target =
parseInt(
document.getElementById("targetTotal").value
);

if(isNaN(target)){

alert("Masukkan total");
return;

}

let hasil =
generateTotal(target);

if(!hasil) return;

for(let i=0;i<9;i++){

dices[i].innerText =
hasil[i];

}

updateTotal();
}

updateTotal();

</script>

</body>
</html>
